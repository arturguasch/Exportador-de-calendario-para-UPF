{
  "manifest_version": 3,
  "name": "Exportador de calendario para UPF",
  "version": "1.0.0",
  "description": "Exporta el calendario de la UPF a .ics con opciones por asignatura.",
  "action": {
    "default_title": "Exportador de calendario para UPF",
    "default_popup": "popup.html"
  },
  "permissions": [
    "scripting",
    "downloads",
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://secretariavirtual.upf.edu/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
